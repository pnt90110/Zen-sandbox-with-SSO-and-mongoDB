{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.js" },
    { "src": "/login", "dest": "api/index.js" },
    { "src": "/logout", "dest": "api/index.js" },
    { "src": "/callback", "dest": "api/index.js" },
    { "src": "/styles.css", "dest": "/frontend/styles.css" },
    { "src": "/src/(.*)", "dest": "/frontend/src/$1" },
    { "src": "/(.*)", "dest": "/frontend/index.html" }
  ]
}
